# Runtime
NODE_ENV=development
PORT=3000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage (ensure OUTPUT_DIR matches the path served by /downloads)
OUTPUT_DIR=storage/output
TEMP_DIR=storage/temp

# Queue
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT=300000

# Worker
WORKER_CONCURRENCY=2
WORKER_RATE_LIMIT_MAX=10
WORKER_RATE_LIMIT_DURATION=60000

# Autoscaling hints (used by worker manager service if wired up)
QUEUE_THRESHOLD=5
MAX_WORKERS=0
SCALE_CHECK_INTERVAL=60000

# Monitoring
ENABLE_MONITORING=false
METRICS_INTERVAL=15000
